<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/sheetRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#1E293B"
    android:orientation="vertical"
    android:padding="24dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:background="#334155"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/tvSheetTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SESSION INTELLIGENCE"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:letterSpacing="0.1" />

    <TextView
        android:id="@+id/tvSheetDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Loading session data..."
        android:textColor="#94A3B8"
        android:textSize="13sp"
        android:layout_marginTop="4dp" />

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:columnCount="2"
        android:rowCount="2">

        <!-- Safety Score Box -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cardBackgroundColor="#0F172A"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="#334155"
            app:strokeWidth="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SAFETY SCORE"
                    android:textColor="#94A3B8"
                    android:textSize="9sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvSheetScore"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="--%"
                    android:textColor="#22C55E"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Duration Box -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cardBackgroundColor="#0F172A"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="#334155"
            app:strokeWidth="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="DRIVE TIME"
                    android:textColor="#94A3B8"
                    android:textSize="9sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvSheetDuration"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="--m --s"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Alerts Box -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cardBackgroundColor="#0F172A"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="#334155"
            app:strokeWidth="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ALERTS FIRED"
                    android:textColor="#94A3B8"
                    android:textSize="9sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvSheetAlerts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#EF4444"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Focus Box -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cardBackgroundColor="#0F172A"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="#334155"
            app:strokeWidth="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="EST. FOCUS"
                    android:textColor="#94A3B8"
                    android:textSize="9sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvSheetFocus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="--%"
                    android:textColor="#38BDF8"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </GridLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCloseSheet"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="24dp"
        android:text="CLOSE ANALYSIS"
        android:textColor="#0F172A"
        android:textStyle="bold"
        app:backgroundTint="#38BDF8"
        app:cornerRadius="16dp" />
</LinearLayout>
