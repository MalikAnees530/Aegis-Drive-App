<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deepest">

    <!-- 1. MAP LAYER -->
    <org.osmdroid.views.MapView
        android:id="@+id/map"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 2. SEARCH BENTO (Fixed Top) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardSearch"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="48dp"
        app:cardBackgroundColor="#F2121212"
        app:cardCornerRadius="16dp"
        app:cardElevation="12dp"
        app:strokeColor="#4DFFFFFF"
        app:strokeWidth="1dp"
        android:elevation="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔍"
                android:textSize="18sp"
                android:layout_marginEnd="12dp" />
            <AutoCompleteTextView
                android:id="@+id/etSearch"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="Search Areas (e.g. G9, F10, KFC)..."
                android:textColor="#FFFFFF"
                android:textColorHint="#6D8196"
                android:textSize="14sp"
                android:completionThreshold="1"
                android:imeOptions="actionSearch"
                android:inputType="text" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 3. NAVIGATION ACTION BUTTONS -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStartDrive"
        android:layout_width="wrap_content"
        android:layout_height="60dp"
        android:text="↱ START DRIVE"
        android:textColor="#0F172A"
        android:textSize="14sp"
        android:textStyle="bold"
        android:visibility="gone"
        android:elevation="20dp"
        app:backgroundTint="#38BDF8"
        app:cornerRadius="30dp"
        app:layout_constraintBottom_toTopOf="@id/bottomCommandBento"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStopDrive"
        android:layout_width="wrap_content"
        android:layout_height="60dp"
        android:text="✕ CANCEL TRIP"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:visibility="gone"
        android:elevation="20dp"
        app:backgroundTint="#EF5350"
        app:cornerRadius="30dp"
        app:layout_constraintBottom_toTopOf="@id/bottomCommandBento"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp" />

    <!-- 4. TELEMETRY ROW (Speed + Safety Status) -->
    <LinearLayout
        android:id="@+id/telemetryRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:layout_marginTop="12dp"
        android:elevation="12dp"
        app:layout_constraintTop_toBottomOf="@id/cardSearch">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="72dp"
            android:layout_height="72dp"
            app:cardBackgroundColor="#E6FFFFFF"
            app:cardCornerRadius="18dp"
            app:strokeWidth="1dp"
            app:strokeColor="#DDDDDD">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvSpeed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#000000"
                    android:textSize="24sp"
                    android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="km/h" android:textColor="#666666" android:textSize="8sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardStatusIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#CC121212"
            app:cardCornerRadius="18dp"
            app:strokeColor="#33FFFFFF"
            app:strokeWidth="1dp">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp"
                android:gravity="center_vertical">
                <View
                    android:id="@+id/statusDot"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/ic_launcher_background"
                    android:backgroundTint="@color/status_safe"
                    android:layout_marginEnd="6dp" />
                <TextView
                    android:id="@+id/tvStatusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI SAFE"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- 5. 2-SECOND GLANCE CARD -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardRouting"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        app:cardBackgroundColor="#F2121212"
        app:cardCornerRadius="24dp"
        app:strokeColor="#4DFFFFFF"
        app:strokeWidth="1dp"
        android:visibility="gone"
        android:elevation="12dp"
        app:layout_constraintTop_toBottomOf="@id/telemetryRow">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="↱"
                android:textColor="@color/accent_light"
                android:textSize="28sp"
                android:layout_marginEnd="12dp"
                android:textStyle="bold" />
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvNavDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvNavStreet"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Awaiting Route"
                    android:textColor="#A0A0A0"
                    android:textSize="12sp" />
            </LinearLayout>
            <TextView
                android:id="@+id/tvRemainingTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-- min"
                android:textColor="@color/accent_light"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- GPS CENTER BUTTON -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/btnCenterLocation"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="#E6FFFFFF"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:strokeColor="#DDDDDD"
        app:strokeWidth="1dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintBottom_toTopOf="@id/bottomCommandBento"
        app:layout_constraintEnd_toEndOf="parent">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="🎯"
            android:textSize="20sp" />
    </com.google.android.material.card.MaterialCardView>

    <!-- 6. BOTTOM COMMAND BENTO -->
    <LinearLayout
        android:id="@+id/bottomCommandBento"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingBottom="40dp"
        android:elevation="15dp"
        android:gravity="bottom"
        android:weightSum="5"
        app:layout_constraintBottom_toBottomOf="parent">
        
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnSafeHarbor"
            android:layout_width="0dp" android:layout_height="64dp" android:layout_weight="1" android:layout_marginEnd="4dp"
            app:cardBackgroundColor="@color/bg_surface" app:cardCornerRadius="16dp" app:strokeColor="@color/border_subtle" app:strokeWidth="1dp"
            android:clickable="true" android:focusable="true">
            <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="🏨" android:textSize="22sp" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnFood"
            android:layout_width="0dp" android:layout_height="64dp" android:layout_weight="1" android:layout_marginHorizontal="4dp"
            app:cardBackgroundColor="@color/bg_surface" app:cardCornerRadius="16dp" app:strokeColor="@color/border_subtle" app:strokeWidth="1dp"
            android:clickable="true" android:focusable="true">
            <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="🍔" android:textSize="22sp" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnGas"
            android:layout_width="0dp" android:layout_height="64dp" android:layout_weight="1" android:layout_marginHorizontal="4dp"
            app:cardBackgroundColor="@color/bg_surface" app:cardCornerRadius="16dp" app:strokeColor="@color/border_subtle" app:strokeWidth="1dp"
            android:clickable="true" android:focusable="true">
            <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="⛽" android:textSize="22sp" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardVoiceSearch"
            android:layout_width="0dp" android:layout_height="64dp" android:layout_weight="2" android:layout_marginStart="4dp"
            app:cardBackgroundColor="@color/bg_surface" app:cardCornerRadius="32dp" app:strokeColor="@color/border_subtle" app:strokeWidth="1dp"
            android:clickable="true" android:focusable="true">
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="horizontal" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🎤 VOICE" android:textStyle="bold" android:textColor="@color/accent_primary" android:textSize="12sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- INTERNAL VOICE OVERLAY -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/voiceOverlay"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:visibility="gone"
        android:elevation="100dp"
        app:cardBackgroundColor="#E6121212"
        app:cardCornerRadius="100dp"
        app:strokeColor="@color/accent_primary"
        app:strokeWidth="3dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎤"
                android:textSize="48sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LISTENING..."
                android:textColor="@color/accent_primary"
                android:textStyle="bold"
                android:textSize="12sp"
                android:layout_marginTop="8dp"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>