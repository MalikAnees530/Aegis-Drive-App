<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deepest">

    <!-- MAIN CHAT CONTENT -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- 🚀 PREMIUM SAFETY HEADER -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/chatHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardBackgroundColor="@color/bg_surface"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/border_subtle"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnMenu"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:cardBackgroundColor="@color/bg_elevated"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_menu"
                        app:tint="@color/accent_primary"/>
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Aegis Intelligence"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tvSafetyMirror"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AI SAFE • 100%"
                        android:textColor="@color/status_safe"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"/>
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnNewChat"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    app:cardBackgroundColor="@color/bg_elevated"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="+"
                        android:textColor="@color/accent_primary"
                        android:textSize="24sp"
                        android:textStyle="bold"/>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- CHAT MESSAGES AREA -->
        <ScrollView
            android:id="@+id/chatScrollView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginHorizontal="16dp"
            android:paddingBottom="8dp"
            android:clipToPadding="false"
            app:layout_constraintTop_toBottomOf="@id/chatHeader"
            app:layout_constraintBottom_toTopOf="@id/quickChipsRow">

            <LinearLayout
                android:id="@+id/chatMessagesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="8dp"/>
        </ScrollView>

        <!-- 🚀 QUICK ACTION CHIPS -->
        <HorizontalScrollView
            android:id="@+id/quickChipsRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:scrollbars="none"
            app:layout_constraintBottom_toTopOf="@id/chatInputBar">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/chipSafety"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="@color/bg_surface"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/border_subtle"
                    app:strokeWidth="1dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🛡️ Safety Score" android:textColor="@color/text_primary" android:textSize="11sp" android:paddingHorizontal="14dp" android:paddingVertical="8dp" android:textStyle="bold"/>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/chipHospital"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="@color/bg_surface"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/border_subtle"
                    app:strokeWidth="1dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🏥 Nearest Hospital" android:textColor="@color/text_primary" android:textSize="11sp" android:paddingHorizontal="14dp" android:paddingVertical="8dp" android:textStyle="bold"/>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/chipHome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/bg_surface"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/border_subtle"
                    app:strokeWidth="1dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🏠 Navigate Home" android:textColor="@color/text_primary" android:textSize="11sp" android:paddingHorizontal="14dp" android:paddingVertical="8dp" android:textStyle="bold"/>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </HorizontalScrollView>

        <!-- INPUT BAR -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/chatInputBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/bg_surface"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            app:strokeColor="@color/border_subtle"
            app:strokeWidth="1dp"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="8dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnMic"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="@color/accent_primary"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_mic"
                        app:tint="@color/bg_deepest"/>
                </com.google.android.material.card.MaterialCardView>

                <EditText
                    android:id="@+id/etChatInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Talk to Aegis..."
                    android:textColorHint="@color/text_disabled"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:background="@null"
                    android:inputType="text"
                    android:imeOptions="actionSend"
                    android:maxLines="3"
                    android:paddingHorizontal="8dp"/>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnSend"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    app:cardBackgroundColor="@color/bg_deepest"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/accent_primary"
                    app:strokeWidth="1dp">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_navigate"
                        android:rotation="45"
                        app:tint="@color/accent_primary"/>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 🚀 SESSION DRAWER -->
    <com.google.android.material.navigation.NavigationView
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/bg_surface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recent Chats"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="20dp"/>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">
                <LinearLayout
                    android:id="@+id/sessionsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>
            </ScrollView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeleteAllSessions"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Delete All Sessions"
                android:textColor="#EF4444"
                android:textAllCaps="false"/>

        </LinearLayout>
    </com.google.android.material.navigation.NavigationView>

</androidx.drawerlayout.widget.DrawerLayout>