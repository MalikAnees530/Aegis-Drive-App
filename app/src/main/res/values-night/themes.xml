<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 🚀 Premium Android 12+ Native Splash Theme (Night Mode) -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/bg_navy</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_aegis_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.AegisDrive</item>
    </style>

    <!-- Base application theme (Modern Material 3) -->
    <style name="Theme.AegisDrive" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/aegis_blue</item>
        <item name="android:windowBackground">@color/bg_navy</item>
        <item name="android:statusBarColor">@color/bg_navy</item>
        <item name="android:navigationBarColor">@color/bg_navy</item>
        <item name="android:windowLightStatusBar">false</item>
        
        <item name="materialCardViewStyle">@style/AegisDrive.CardView</item>
    </style>

    <style name="AegisDrive.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/bg_navy_light</item>
        <item name="cardCornerRadius">16dp</item>
    </style>

    <style name="CustomDialogTheme" parent="Theme.Material3.DayNight.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowNoTitle">true</item>
    </style>
</resources>
