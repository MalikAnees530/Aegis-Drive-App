<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.AegisDrive" parent="Theme.MaterialComponents.DayNight.NoActionBar">

        <!-- Primary brand color -->
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorPrimaryVariant">@color/accent_dark</item>
        <item name="colorOnPrimary">@color/text_primary</item>

        <!-- Secondary color -->
        <item name="colorSecondary">@color/text_secondary</item>
        <item name="colorSecondaryVariant">@color/text_disabled</item>
        <item name="colorOnSecondary">@color/bg_deepest</item>

        <!-- App background -->
        <item name="android:colorBackground">@color/bg_deepest</item>
        <item name="colorOnBackground">@color/text_primary</item>

        <!-- Surface -->
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <!-- Error -->
        <item name="colorError">@color/status_danger</item>
        <item name="colorOnError">@color/text_primary</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/bg_deepest</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Navigation bar — dark, no translucency -->
        <item name="android:navigationBarColor">@color/bg_deepest</item>
        <item name="android:windowTranslucentNavigation">false</item>
        <item name="android:windowTranslucentStatus">false</item>

        <!-- Window background -->
        <item name="android:windowBackground">@color/bg_deepest</item>

        <!-- REMOVED: android:windowSoftInputMode from theme (causes scroll conflicts)
             Each Activity declares its own softInputMode in AndroidManifest.xml -->

        <!-- Text -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_disabled</item>

        <!-- Ripple -->
        <item name="rippleColor">@color/accent_primary</item>

        <!-- Default component styles -->
        <item name="materialCardViewStyle">@style/AegisDrive.CardView</item>
        <item name="textInputStyle">@style/AegisDrive.TextInputLayout</item>
        <item name="materialButtonStyle">@style/AegisDrive.Button.Primary</item>

    </style>


    <!-- ============================================ -->
    <!--           COMPONENT STYLES                   -->
    <!-- ============================================ -->

    <!-- Card View -->
    <style name="AegisDrive.CardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/bg_surface</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/border_subtle</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Text Input -->
    <style name="AegisDrive.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/bg_elevated</item>
        <item name="boxStrokeColor">@color/border_visible</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_disabled</item>
    </style>

    <!-- Primary Button -->
    <style name="AegisDrive.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/accent_primary</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">28dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="rippleColor">@color/accent_dark</item>
    </style>

    <!-- Outlined Button -->
    <style name="AegisDrive.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/accent_primary</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="android:textColor">@color/accent_primary</item>
        <item name="android:textSize">15sp</item>
        <item name="cornerRadius">28dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>

    <!-- Text Button -->
    <style name="AegisDrive.Button.Text" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/accent_light</item>
        <item name="android:textSize">14sp</item>
        <item name="rippleColor">@color/accent_dark</item>
    </style>

    <!-- Heading Text -->
    <style name="AegisDrive.Text.Heading" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <!-- Subheading Text -->
    <style name="AegisDrive.Text.Subheading" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Body Text -->
    <style name="AegisDrive.Text.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <!-- Caption Text -->
    <style name="AegisDrive.Text.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/text_disabled</item>
        <item name="android:textSize">12sp</item>
    </style>

    <!-- Status Badge Safe -->
    <style name="AegisDrive.StatusBadge.Safe" parent="Widget.MaterialComponents.Chip.Action">
        <item name="chipBackgroundColor">#1A6ABF69</item>
        <item name="android:textColor">@color/status_safe</item>
        <item name="chipStrokeColor">@color/status_safe</item>
        <item name="chipStrokeWidth">1dp</item>
    </style>

    <!-- Status Badge Danger -->
    <style name="AegisDrive.StatusBadge.Danger" parent="Widget.MaterialComponents.Chip.Action">
        <item name="chipBackgroundColor">#1AEF5350</item>
        <item name="android:textColor">@color/status_danger</item>
        <item name="chipStrokeColor">@color/status_danger</item>
        <item name="chipStrokeWidth">1dp</item>
    </style>

</resources>