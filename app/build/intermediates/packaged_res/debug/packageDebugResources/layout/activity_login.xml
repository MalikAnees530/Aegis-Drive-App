<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deepest"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- DECORATIVE HEADER -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:background="#0D1B26">

            <!-- Corner Accents -->
            <View android:layout_width="20dp" android:layout_height="2dp" android:layout_gravity="top|start" android:layout_margin="20dp" android:background="@color/accent_primary" />
            <View android:layout_width="2dp" android:layout_height="20dp" android:layout_gravity="top|start" android:layout_margin="20dp" android:background="@color/accent_primary" />
            <View android:layout_width="20dp" android:layout_height="2dp" android:layout_gravity="top|end" android:layout_margin="20dp" android:background="@color/accent_primary" />
            <View android:layout_width="2dp" android:layout_height="20dp" android:layout_gravity="top|end" android:layout_margin="20dp" android:background="@color/accent_primary" />

            <View android:layout_width="20dp" android:layout_height="2dp" android:layout_gravity="bottom|start" android:layout_margin="20dp" android:background="@color/accent_dark" />
            <View android:layout_width="2dp" android:layout_height="20dp" android:layout_gravity="bottom|start" android:layout_margin="20dp" android:background="@color/accent_dark" />
            <View android:layout_width="20dp" android:layout_height="2dp" android:layout_gravity="bottom|end" android:layout_margin="20dp" android:background="@color/accent_dark" />
            <View android:layout_width="2dp" android:layout_height="20dp" android:layout_gravity="bottom|end" android:layout_margin="20dp" android:background="@color/accent_dark" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingBottom="16dp">

                <!-- Logo Icon -->
                <FrameLayout
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:layout_gravity="center_horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="88dp"
                        android:layout_height="88dp"
                        android:layout_gravity="center"
                        app:cardBackgroundColor="@android:color/transparent"
                        app:cardCornerRadius="44dp"
                        app:cardElevation="0dp"
                        app:strokeColor="#2A4558"
                        app:strokeWidth="1dp" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_gravity="center"
                        app:cardBackgroundColor="#1A3D5573"
                        app:cardCornerRadius="22dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/accent_primary"
                        app:strokeWidth="2dp">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="◉"
                            android:textColor="@color/accent_light"
                            android:textSize="20sp" />
                    </com.google.android.material.card.MaterialCardView>

                    <View android:layout_width="12dp" android:layout_height="1dp" android:layout_gravity="center_vertical|start" android:background="@color/accent_primary" />
                    <View android:layout_width="12dp" android:layout_height="1dp" android:layout_gravity="center_vertical|end" android:background="@color/accent_primary" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="AEGIS DRIVE"
                    android:textColor="@color/text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.22"
                    android:fontFamily="sans-serif-condensed" />

                <View
                    android:layout_width="32dp"
                    android:layout_height="2dp"
                    android:layout_marginTop="8dp"
                    android:background="@color/accent_primary"
                    android:layout_gravity="center_horizontal" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="DRIVER SAFETY INTELLIGENCE"
                    android:textColor="@color/accent_dark"
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>

        <!-- FORM SECTION -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="36dp"
            android:paddingBottom="48dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="32dp">

                <View
                    android:layout_width="4dp"
                    android:layout_height="40dp"
                    android:background="@color/accent_primary"
                    android:layout_marginEnd="16dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Welcome Back"
                        android:textColor="@color/text_primary"
                        android:textSize="26sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Sign in to your secure account"
                        android:textColor="@color/text_disabled"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Email Field -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/emailInputLayout"
                style="@style/AegisDrive.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:hint="Email Address"
                app:startIconDrawable="@drawable/ic_email"
                app:startIconTint="@color/accent_primary"
                app:errorEnabled="true">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/text_primary" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Password Field -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/passwordInputLayout"
                style="@style/AegisDrive.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="Password"
                app:startIconDrawable="@drawable/ic_lock"
                app:startIconTint="@color/accent_primary"
                app:passwordToggleEnabled="true"
                app:passwordToggleTint="@color/accent_primary"
                app:errorEnabled="true">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:textColor="@color/text_primary" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/tvForgotPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:text="Forgot Password?"
                android:textColor="@color/accent_light"
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingVertical="8dp"
                android:layout_marginBottom="24dp" />

            <!-- Sign In Button (Refined) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogin"
                style="@style/AegisDrive.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="Sign In"
                android:textAllCaps="false"
                android:letterSpacing="0.05"
                android:textSize="17sp"
                app:cornerRadius="14dp"
                app:icon="@drawable/ic_navigate"
                app:iconGravity="textEnd"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <!-- Divider -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="36dp"
                android:layout_marginBottom="28dp">
                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="@color/border_subtle" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:text="NEW TO AEGIS?"
                    android:textColor="@color/text_disabled"
                    android:letterSpacing="0.1"
                    android:textSize="11sp"
                    android:textStyle="bold" />
                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="@color/border_subtle" />
            </LinearLayout>

            <!-- Create Account Button (Refined) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/tvGoToSignUp"
                style="@style/AegisDrive.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="Create My Account"
                android:textAllCaps="false"
                android:letterSpacing="0.05"
                android:textSize="16sp"
                app:cornerRadius="14dp"
                app:icon="@drawable/ic_person"
                app:iconPadding="12dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="36dp"
                android:text="v1.0.0  ·  Secured by Aegis Intelligence"
                android:textColor="@color/text_disabled"
                android:textSize="11sp"
                android:gravity="center"
                android:letterSpacing="0.05" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>